{%- if menu|length > 1 ~%}
<nav class="navbar navbar-expand-lg">
    <div class="container d-flex flex-row justify-content-between align-items-center">
        <div class="navbar-nav d-flex flex-row align-items-center">
            <div class="nav-item px-2">
                <a href="#" data-theme-toggle title="{{ 'change_theme'|trans }}">
                    <i class="fas fa-moon"></i>
                </a>
            </div>
            <div class="nav-item px-2">
                {%- set targetLang = site.language == 'fr' ? 'en' : 'fr' -%}
                {%- set translation = page.translations|filter(t => t.language == targetLang)|first -%}
                {%- if translation -%}
                    {%- set targetUrl = url(translation) -%}
                {%- else -%}
                    {%- set targetUrl = targetLang == 'fr' ? url('fr/' ~ page.id) : url(page.id) -%}
                {%- endif -%}
                <a href="{{ targetUrl }}" title="{{ targetLang == 'fr' ? 'switch_to_french'|trans : 'switch_to_english'|trans }}">
                    {{- targetLang == 'fr' ? '🇫🇷' : '🇬🇧' -}}
                </a>
            </div>
            <div class="nav-item px-2 dropdown">
                <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" title="{{ 'feeds'|trans }}" aria-label="{{ 'feeds'|trans }}">
                    <i class="fas fa-rss"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="{{ url('feed.xml') }}">{{ 'rss_feed'|trans }}</a></li>
                    <li><a class="dropdown-item" href="{{ url('atom.xml') }}">{{ 'atom_feed'|trans }}</a></li>
                    <li><a class="dropdown-item" href="{{ url('feed.json') }}">{{ 'json_feed'|trans }}</a></li>
                    <li><a class="dropdown-item" href="{{ url('feed.md') }}">{{ 'llm_feed'|trans }}</a></li>
                </ul>
            </div>
        </div>
        {%- set menu_keys = {index: 'home', blog: 'blog', 'about-me': 'about_me', legal: 'legal', tags: 'tags_label'} ~%}
        <div class="navbar-nav d-flex flex-row align-items-center">
            {%- for item in site.menus[menu]|sort_by_weight ~%}
                <div class="nav-item px-2">
                    <a class="nav-link" href="{{ url(item.id, {language: site.language}) }}">{{ attribute(menu_keys, item.id)|default('menu_' ~ item.id)|trans }}</a>
                </div>
            {%- endfor ~%}
        </div>
    </div>
</nav>
{%- endif ~%}
