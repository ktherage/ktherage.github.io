{#- navigation between list/pages ~#}
{%- if page.prev is defined or page.next is defined ~%}
    <div class="page-nav">
        {%- if page.prev is defined ~%}
            <a class="page-nav prev" href="{{ url(page.prev) }}">{{ 'previous_article'|trans({'%title%': page.prev.title}) }}</a>
        {%- endif ~%}
        {%- if page.next is defined ~%}
            <a class="page-nav next" href="{{ url(page.next) }}">{{ 'next_article'|trans({'%title%': page.next.title}) }}</a>
        {%- endif ~%}
    </div>
{%- endif ~%}
