{
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Person",
            "@id": "{{ url(site, {canonical: true}) }}#person",
            "name": "{{ site.author.name|e('js') }}",
            "url": "{{ site.author.url|default(url(site, {canonical: true})) }}",
            "image": "{{ url(asset(site.author.image), {canonical: true}) }}",
            "jobTitle": "{{ site.author.title|e('js') }}",
            "description": "{{ site.author.bio|default(site.description)|e('js') }}",
            "sameAs": [
                {%- for social in site.social|default([]) %}
                "{{ social.url|e('js') }}"{% if not loop.last %},{% endif %}
                {%- endfor %}
            ]
        },
        {
            "@type": "WebSite",
            "@id": "{{ url(site, {canonical: true}) }}#website",
            "url": "{{ url(site, {canonical: true}) }}",
            "name": "{{ site.title|e('js') }}",
            "description": "{{ site.description|e('js') }}",
            "publisher": {
                "@id": "{{ url(site, {canonical: true}) }}#person"
            },
            "inLanguage": "{{ site.language }}",
            "potentialAction": {
                "@type": "SearchAction",
                "target": {
                    "@type": "EntryPoint",
                    "urlTemplate": "{{ url(site, {canonical: true}) }}?s={search_term_string}"
                },
                "query-input": "required name=search_term_string"
            }
        }
    ]
}
