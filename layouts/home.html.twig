{% extends "_default/page.html.twig" %}

{%- set latest_posts = site.pages|filter(p => p.section == 'blog' and p.title is defined and p.date <= date() and p.id != page.id and p.virtual == false)|sort_by_date|slice(0, 3) -%}

{% block content %}
    <div class="container">
        <header class="d-flex flex-column justify-content-center align-items-center text-center my-5 py-4" role="banner" style="min-height: 85vh">
            <div class="profile-image-container mb-4" aria-hidden="true">
                <img
                    src="{{ url(site.author.image|resize(256)) }}"
                    srcset="{{ url(site.author.image|resize(128)) }} 128w,
                            {{ url(site.author.image|resize(256)) }} 256w,
                            {{ url(site.author.image|resize(512)) }} 512w"
                    sizes="(max-width: 768px) 128px, 256px"
                    width="200"
                    height="200"
                    class="rounded-circle profile-image"
                    alt="{{ site.author.name }} – {{ site.author.title }}"
                    aria-hidden="false"
                    decoding="async"
                    fetchpriority="high"
                >
            </div>

            <h1 class="display-4 fw-bold my-0">
                {{ site.author.name }}
            </h1>

            <h2 class="text-muted mt-0 mb-4">
                {{ site.author.title|capitalize }}
            </h2>

            <div class="lead mb-5">
                {{ 'baseline'|trans|raw }}
            </div>

            <!-- Section Contact -->
            <div class="row d-flex flex-row justify-content-around align-items-center social-links" role="list" aria-label="{{ 'social_links'|trans }}">
                {% for social in site.social %}
                    <a href="{{ social.url }}"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="col-sm-3 col-md-1 text-decoration-none d-flex flex-row justify-content-center align-items-center flex-column text-center mx-2 my-2"
                        aria-label="{{ 'follow_on'|trans({'%name%': social.name|capitalize}) }}"
                        role="listitem"
                        style="height: 150px;"
                        {% if social.name == 'email' %}rel="me"{% endif %}
                    >
                        <i class="{{ social.icon }} fa-4x" aria-hidden="true"></i>
                        <span>{{ social.name }}</span>
                        <span class="visually-hidden">{{ social.url }}</span>
                    </a>
                {% endfor %}
            </div>
        </header>

        <!-- Expertise section -->
        <section class="expertise border-top py-5" aria-labelledby="expertise-heading">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <h3 id="expertise-heading" class="text-center mb-4">{{ 'expertise_heading'|trans }}</h3>
                    <p class="mb-3">{{ 'expertise_intro'|trans }}</p>
                    <p class="mb-4">{{ 'expertise_outro'|trans }}</p>
                    <a href="{{ url('about-me/') }}" class="btn btn-outline-primary">
                        {{ 'read_more_about_me'|trans }} <i class="fas fa-arrow-right ms-2" aria-hidden="true"></i>
                    </a>
                </div>
            </div>
        </section>

        <!-- Last articles -->
        <section class="latest-posts py-5 border-top" aria-labelledby="latest-posts-heading">
            <h3 id="latest-posts-heading" class="text-center mb-5">{{ 'last_articles'|trans }}</h3>
            <div class="row g-4" role="list">
                {% include 'partials/post-card.html.twig' with {pages: latest_posts} %}
            </div>
            <div class="text-center mt-5">
                <a href="{{ url('blog/') }}" class="btn btn-primary" aria-label="{{ 'view_articles'|trans }}">
                    {{ 'view_articles'|trans }} <i class="fas fa-arrow-right ms-2" aria-hidden="true"></i>
                </a>
            </div>
        </section>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    {%- if latest_posts is defined and latest_posts|length > 0 -%}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Blog",
        "@id": "{{ url('blog/', {canonical: true}) }}#blog",
        "name": "Blog de {{ site.author.name }}",
        "description": "{{ site.description|e('js') }}",
        "blogPost": [
            {%- for post in latest_posts %}
            {
                "@type": "BlogPosting",
                "headline": "{{ post.title|e('js') }}",
                "url": "{{ url(post, {canonical: true}) }}",
                "datePublished": "{{ post.date|date('c') }}",
                "dateModified": "{{ post.updated|default(post.date)|date('c') }}",
                "description": "{{ post.description|default(post.excerpt|striptags)|e('js') }}",
                "mainEntityOfPage": {
                    "@type": "WebPage",
                    "@id": "{{ url(post, {canonical: true}) }}"
                }{% if post.image is defined and post.image is not null %},
                "image": {
                    "@type": "ImageObject",
                    "url": "{{ url(asset(post.image), {canonical: true}) }}",
                    "width": "1200",
                    "height": "630"
                }{% endif %}
            }{% if not loop.last %},{% endif %}
            {%- endfor %}
        ]
    }
    </script>
    {%- endif -%}
{% endblock %}
