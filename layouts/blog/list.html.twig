{% extends '_default/list.html.twig' %}

{% block content %}
    <main class="d-flex flex-column flex-grow-1">
        <div class="container my-5">
            <header class="mb-5 text-center">
                <h1 class="display-5 fw-bold">{{ page.title }}</h1>
                {% if page.content %}
                    <p class="lead text-muted">{{ page.content }}</p>
                {% endif %}
            </header>

            {# Tag cloud — sourced from Cecil's vocabulary, so the badge list is always in sync with the taxonomy #}
            {% set tags_vocab = site.taxonomies.get('tags') %}
            {% if tags_vocab and tags_vocab|length > 0 %}
                <div class="mb-4 text-center">
                    <span class="badge bg-secondary me-2 mb-2 filter-badge active" data-filter="all"
                          style="cursor: pointer;">{{ 'all_label'|trans }}</span>
                    {% for term in tags_vocab|sort_by_title %}
                        <span class="badge bg-secondary me-2 mb-2 filter-badge" data-filter="{{ term.name|slugify }}"
                              style="cursor: pointer;">{{ term.name }}</span>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="row g-4" role="list" id="blog-posts">
                {% include 'partials/post-card.html.twig' with {pages: pages} %}
            </div>

            <footer class="mt-5">
                {{ include('partials/paginator.html.twig', {page}, with_context = false) }}
            </footer>
        </div>

        <script>
            // Filtrage par tags
            document.addEventListener('DOMContentLoaded', function () {
                const filterBadges = document.querySelectorAll('.filter-badge');
                const blogPosts = document.querySelectorAll('.blog-post-item');

                filterBadges.forEach(badge => {
                    badge.addEventListener('click', function () {
                        const filter = this.getAttribute('data-filter');

                        // Mise à jour des badges actifs
                        filterBadges.forEach(b => {
                            b.classList.remove('active', 'bg-primary');
                            b.classList.add('bg-secondary');
                        });
                        this.classList.remove('bg-secondary');
                        this.classList.add('active', 'bg-primary');

                        // Filtrage des articles
                        blogPosts.forEach(post => {
                            const tags = (post.getAttribute('data-tags') || '').split(',').filter(Boolean);
                            if (filter === 'all' || tags.includes(filter)) {
                                post.style.display = 'block';
                            } else {
                                post.style.display = 'none';
                            }
                        });
                    });
                });
            });
        </script>
    </main>
{% endblock content %}
