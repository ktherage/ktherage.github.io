{% extends '_default/page.html.twig' %}

{% block head %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/heading-anchors.css') }}">
{% endblock %}

{%- block content ~%}
    <div class="container my-5">
        {# Floating table of contents #}
        <aside id="toc" class="toc-floating" aria-label="{{ 'toc_title'|trans|default('On this page') }}">
            <p class="toc-title">{{ 'toc_title'|trans|default('On this page') }}</p>
            <ul id="toc-list" class="toc-list"></ul>
        </aside>
        <button id="toc-toggle" class="toc-toggle" type="button" aria-label="{{ 'toc_toggle'|trans|default('Toggle table of contents') }}" aria-expanded="false">
            <i class="fas fa-list" aria-hidden="true"></i>
        </button>

        <div class="row justify-content-center">
            <div class="col-lg-12 col-xl-10">
                <article class="blog-post">
                    <header class="mb-4 pb-4 border-bottom">
                        {# Image de cover #}
                        {% if page.cover is defined and page.cover.image %}
                            <div class="d-flex flex-wrap align-items-center justify-content-center mb-4">
                                <img src="{{ asset(page.cover.image) }}"
                                    alt="{{ post.cover.alt|default('cover_image_for'|trans({'%title%': page.title})) }}"
                                    class="img-fluid rounded shadow-sm w-100"
                                    style="max-height: 400px; object-fit: cover;">
                                {% if page.cover.caption is defined and page.cover.caption is not null %}
                                    <p class="text-muted text-center mb-0">{{ page.cover.caption|raw }}</p>
                                {% endif %}
                            </div>
                        {% endif %}
                        <h1 class="display-5 fw-bold mb-3">{{ page.title|e }}</h1>
                        <div class="d-flex flex-wrap align-items-center gap-3 text-muted mb-3">
                            <time class="small">
                                <i class="bi bi-calendar3 me-1"></i>
                                {{ page.date|format_date('long') }}
                            </time>
                        </div>
                        {% if page.tags is defined %}
                            <div class="mb-2">
                                {% for tag in page.tags %}
                                    <a href="{{ url('tags/' ~ tag|slugify) }}" class="badge bg-secondary text-decoration-none me-1 mb-1">{{ tag }}</a>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </header>

                    <main class="blog-content">
                        {{ page.content }}
                    </main>

                    <footer class="mt-5 pt-4 border-top">
                        {{- include('partials/page-navigation.html.twig', {page}, with_context = false) ~}}
                    </footer>
                </article>

                {% if page.comments is not defined or page.comments %}
                    <hr class="my-5">
                    <section id="comments" class="mt-4">
                        <h2 class="h4 mb-4">{{ 'comments'|trans }}</h2>
                        <div id="giscus-comments"></div>
                    </section>
                {% endif %}
            </div>
        </div>
    </div>
{%- endblock content ~%}

{%- block javascripts ~%}
    {{ parent() }}
    <script src="{{ asset('vendor/mermaid-11.15.0/mermaid.min.js') }}"></script>
    <script>
        mermaid.initialize({ theme: 'neutral' });
    </script>
    <script src="{{ asset('vendor/highlightjs-11.11.1/highlight.min.js') }}"></script>
    <script>hljs.highlightAll();</script>
    <script src="{{ asset('js/heading-anchors.js') }}"></script>
    <script src="{{ asset('js/table-of-content.js') }}"></script>
{%- endblock javascripts ~%}
